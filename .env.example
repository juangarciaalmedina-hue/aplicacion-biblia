OPENROUTER_API_KEY=pon_aqui_tu_clave

# Recomendado para buena calidad multidioma con coste moderado
OPENROUTER_MODEL=openai/gpt-4o-mini

# Fallbacks automáticos si el modelo principal falla o responde peor
OPENROUTER_FALLBACK_MODELS=google/gemini-2.5-flash-lite,deepseek/deepseek-chat

# Más bajo = respuestas más estables y menos caóticas
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_TOP_P=0.9
